<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="22505" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="22504"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <collectionViewCell opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="center" id="cell-01" customClass="ActorCell" customModule="IMDUMB" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="80" height="110"/>
            <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>
            <collectionViewCellContentView key="contentView" opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="center" insetsLayoutMarginsFromSafeArea="NO" id="content-01">
                <rect key="frame" x="0.0" y="0.0" width="80" height="110"/>
                <autoresizingMask key="autoresizingMask"/>
                <subviews>
                    <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFill" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="photo-img">
                        <rect key="frame" x="10" y="0.0" width="60" height="60"/>
                        <constraints>
                            <constraint firstAttribute="width" constant="60" id="w-ph"/>
                            <constraint firstAttribute="height" constant="60" id="h-ph"/>
                        </constraints>
                    </imageView>
                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Name" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="name-lbl">
                        <rect key="frame" x="0.0" y="66" width="80" height="16"/>
                        <fontDescription key="fontDescription" type="system" pointSize="11"/>
                        <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                        <nil key="highlightedColor"/>
                    </label>
                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Character" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="char-lbl">
                        <rect key="frame" x="0.0" y="84" width="80" height="14"/>
                        <fontDescription key="fontDescription" type="system" pointSize="10"/>
                        <color key="textColor" systemColor="secondaryLabelColor"/>
                        <nil key="highlightedColor"/>
                    </label>
                </subviews>
                <constraints>
                    <constraint firstItem="photo-img" firstAttribute="top" secondItem="content-01" secondAttribute="top" id="t01"/>
                    <constraint firstItem="photo-img" firstAttribute="centerX" secondItem="content-01" secondAttribute="centerX" id="cx01"/>
                    <constraint firstItem="name-lbl" firstAttribute="top" secondItem="photo-img" secondAttribute="bottom" constant="6" id="t02"/>
                    <constraint firstItem="name-lbl" firstAttribute="leading" secondItem="content-01" secondAttribute="leading" id="l02"/>
                    <constraint firstItem="content-01" firstAttribute="trailing" secondItem="name-lbl" secondAttribute="trailing" id="r02"/>
                    <constraint firstItem="char-lbl" firstAttribute="top" secondItem="name-lbl" secondAttribute="bottom" constant="2" id="t03"/>
                    <constraint firstItem="char-lbl" firstAttribute="leading" secondItem="content-01" secondAttribute="leading" id="l03"/>
                    <constraint firstItem="content-01" firstAttribute="trailing" secondItem="char-lbl" secondAttribute="trailing" id="r03"/>
                </constraints>
            </collectionViewCellContentView>
            <connections>
                <outlet property="photoImageView" destination="photo-img" id="photo-out"/>
                <outlet property="nameLabel" destination="name-lbl" id="name-out"/>
                <outlet property="characterLabel" destination="char-lbl" id="char-out"/>
