<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="22505" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="22504"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <collectionViewCell opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="center" id="cell-01" customClass="MovieCell" customModule="IMDUMB" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="130" height="230"/>
            <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>
            <collectionViewCellContentView key="contentView" opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="center" insetsLayoutMarginsFromSafeArea="NO" id="content-01">
                <rect key="frame" x="0.0" y="0.0" width="130" height="230"/>
                <autoresizingMask key="autoresizingMask"/>
                <subviews>
                    <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFill" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="poster-img">
                        <rect key="frame" x="0.0" y="0.0" width="130" height="180"/>
                        <constraints>
                            <constraint firstAttribute="height" constant="180" id="h-poster"/>
                        </constraints>
                        <userDefinedRuntimeAttributes>
                            <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                                <real key="value" value="10"/>
                            </userDefinedRuntimeAttribute>
                        </userDefinedRuntimeAttributes>
                    </imageView>
                    <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="badge-bg">
                        <rect key="frame" x="0.0" y="0.0" width="42" height="22"/>
                        <subviews>
                            <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="252" verticalHuggingPriority="252" translatesAutoresizingMaskIntoConstraints="NO" id="star-img">
                                <rect key="frame" x="4" y="3" width="14" height="14"/>
                                <color key="tintColor" systemColor="systemYellowColor"/>
                                <constraints>
                                    <constraint firstAttribute="width" constant="14" id="w-star"/>
                                    <constraint firstAttribute="height" constant="14" id="h-star"/>
                                </constraints>
                            </imageView>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="8.5" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="rating-lbl">
                                <rect key="frame" x="22" y="3" width="16" height="16"/>
                                <fontDescription key="fontDescription" type="boldSystem" pointSize="11"/>
                                <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                <nil key="highlightedColor"/>
                            </label>
                        </subviews>
                        <color key="backgroundColor" red="0.0" green="0.0" blue="0.0" alpha="0.69999999999999996" colorSpace="custom" customColorSpace="sRGB"/>
                        <constraints>
                            <constraint firstItem="star-img" firstAttribute="leading" secondItem="badge-bg" secondAttribute="leading" constant="4" id="lead-star"/>
                            <constraint firstItem="star-img" firstAttribute="centerY" secondItem="badge-bg" secondAttribute="centerY" id="cy-star"/>
                            <constraint firstItem="rating-lbl" firstAttribute="leading" secondItem="star-img" secondAttribute="trailing" constant="4" id="lead-rating"/>
                            <constraint firstItem="rating-lbl" firstAttribute="centerY" secondItem="badge-bg" secondAttribute="centerY" id="cy-rating"/>
                            <constraint firstItem="badge-bg" firstAttribute="trailing" secondItem="rating-lbl" secondAttribute="trailing" constant="4" id="trail-rating"/>
                            <constraint firstAttribute="height" constant="22" id="h-badge"/>
                        </constraints>
                        <userDefinedRuntimeAttributes>
                            <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                                <real key="value" value="6"/>
                            </userDefinedRuntimeAttribute>
                        </userDefinedRuntimeAttributes>
                    </view>
                    <imageView clipsSubviews="YES" userInteractionEnabled="YES" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" hidden="YES" translatesAutoresizingMaskIntoConstraints="NO" id="fav-img">
                        <rect key="frame" x="100" y="0" width="30" height="30"/>
                        <constraints>
                            <constraint firstAttribute="width" constant="30" id="w-fav"/>
                            <constraint firstAttribute="height" constant="30" id="h-fav"/>
                        </constraints>
                        <color key="tintColor" systemColor="systemRedColor"/>
                    </imageView>
                    <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" hidden="YES" translatesAutoresizingMaskIntoConstraints="NO" id="rec-img">
                        <rect key="frame" x="106" y="28" width="18" height="18"/>
                        <constraints>
                            <constraint firstAttribute="width" constant="18" id="w-rec"/>
                            <constraint firstAttribute="height" constant="18" id="h-rec"/>
                        </constraints>
                        <color key="tintColor" systemColor="systemGreenColor"/>
                    </imageView>
                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Movie Title" textAlignment="natural" lineBreakMode="tailTruncation" numberOfLines="2" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="title-lbl">
                        <rect key="frame" x="0.0" y="186" width="130" height="32"/>
                        <fontDescription key="fontDescription" type="system" pointSize="13"/>
                        <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                        <nil key="highlightedColor"/>
                    </label>
                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="2024" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="year-lbl">
                        <rect key="frame" x="0.0" y="218" width="130" height="14"/>
                        <fontDescription key="fontDescription" type="system" pointSize="11"/>
                        <color key="textColor" systemColor="secondaryLabelColor"/>
                        <nil key="highlightedColor"/>
                    </label>
                </subviews>
                <color key="backgroundColor" red="0.0" green="0.0" blue="0.0" alpha="0.0" colorSpace="custom" customColorSpace="sRGB"/>
                <constraints>
                    <constraint firstItem="poster-img" firstAttribute="top" secondItem="content-01" secondAttribute="top" id="top-poster"/>
                    <constraint firstItem="poster-img" firstAttribute="leading" secondItem="content-01" secondAttribute="leading" id="lead-poster"/>
                    <constraint firstItem="content-01" firstAttribute="trailing" secondItem="poster-img" secondAttribute="trailing" id="trail-poster"/>
                    <constraint firstItem="badge-bg" firstAttribute="top" secondItem="content-01" secondAttribute="top" constant="6" id="top-badge"/>
                    <constraint firstItem="badge-bg" firstAttribute="leading" secondItem="content-01" secondAttribute="leading" constant="6" id="lead-badge"/>
                    <constraint firstItem="fav-img" firstAttribute="top" secondItem="content-01" secondAttribute="top" constant="0" id="top-fav"/>
                    <constraint firstItem="content-01" firstAttribute="trailing" secondItem="fav-img" secondAttribute="trailing" constant="0" id="trail-fav"/>
                    <constraint firstItem="rec-img" firstAttribute="top" secondItem="fav-img" secondAttribute="bottom" constant="2" id="top-rec"/>
                    <constraint firstItem="content-01" firstAttribute="trailing" secondItem="rec-img" secondAttribute="trailing" constant="6" id="trail-rec"/>
                    <constraint firstItem="title-lbl" firstAttribute="top" secondItem="poster-img" secondAttribute="bottom" constant="6" id="top-title"/>
                    <constraint firstItem="title-lbl" firstAttribute="leading" secondItem="content-01" secondAttribute="leading" id="lead-title"/>
                    <constraint firstItem="content-01" firstAttribute="trailing" secondItem="title-lbl" secondAttribute="trailing" id="trail-title"/>
                    <constraint firstItem="year-lbl" firstAttribute="top" secondItem="title-lbl" secondAttribute="bottom" constant="0" id="top-year"/>
                    <constraint firstItem="year-lbl" firstAttribute="leading" secondItem="content-01" secondAttribute="leading" id="lead-year"/>
                    <constraint firstItem="content-01" firstAttribute="trailing" secondItem="year-lbl" secondAttribute="trailing" id="trail-year"/>
                </constraints>
            </collectionViewCellContentView>
            <connections>
                <outlet property="posterImageView" destination="poster-img" id="poster-out"/>
                <outlet property="titleLabel" destination="title-lbl" id="title-out"/>
                <outlet property="starImageView" destination="star-img" id="star-out"/>
                <outlet property="ratingLabel" destination="rating-lbl" id="rating-out"/>
                <outlet property="yearLabel" destination="year-lbl" id="year-out"/>
                <outlet property="favoriteImageView" destination="fav-img" id="fav-out"/>
                <outlet property="recommendedImageView" destination="rec-img" id="rec-out"/>
            </connections>
            <point key="canvasLocation" x="131" y="75"/>
        </collectionViewCell>
    </objects>
    <resources>
