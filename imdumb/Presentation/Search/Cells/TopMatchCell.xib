<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="22505" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="22504"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <collectionViewCell opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="center" id="cell-root" customClass="TopMatchCell" customModule="IMDUMB" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="361" height="180"/>
            <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>
            <collectionViewCellContentView key="contentView" opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="center" insetsLayoutMarginsFromSafeArea="NO" id="cv">
                <rect key="frame" x="0.0" y="0.0" width="361" height="180"/>
                <autoresizingMask key="autoresizingMask"/>
                <subviews>
                    <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="tm-container">
                        <rect key="frame" x="0.0" y="0.0" width="361" height="180"/>
                        <subviews>
                            <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFill" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="tm-poster">
                                <rect key="frame" x="12" y="12" width="110" height="156"/>
                                <constraints>
                                    <constraint firstAttribute="width" constant="110" id="c-poster-w"/>
                                </constraints>
                            </imageView>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Top Match" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="tm-topLabel">
                                <rect key="frame" x="134" y="12" width="215" height="16"/>
                                <fontDescription key="fontDescription" type="system" pointSize="12"/>
                                <color key="textColor" white="1" alpha="0.6" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                            </label>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Movie Title" textAlignment="natural" lineBreakMode="tailTruncation" numberOfLines="2" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="tm-title">
                                <rect key="frame" x="134" y="32" width="215" height="24"/>
                                <fontDescription key="fontDescription" type="boldSystem" pointSize="18"/>
                                <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                            </label>
                            <stackView opaque="NO" contentMode="scaleToFill" axis="horizontal" spacing="4" translatesAutoresizingMaskIntoConstraints="NO" id="tm-ratingStack">
                                <rect key="frame" x="134" y="62" width="80" height="18"/>
                                <subviews>
                                    <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="252" verticalHuggingPriority="252" image="star.fill" catalog="system" translatesAutoresizingMaskIntoConstraints="NO" id="tm-star">
                                        <rect key="frame" x="0.0" y="0.0" width="18" height="18"/>
                                        <constraints>
                                            <constraint firstAttribute="width" constant="18" id="c-star-w"/>
                                        </constraints>
                                        <color key="tintColor" systemColor="systemYellowColor"/>
                                    </imageView>
                                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="7.0" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="tm-rating">
                                        <rect key="frame" x="22" y="0.0" width="24" height="18"/>
                                        <fontDescription key="fontDescription" type="boldSystem" pointSize="14"/>
                                        <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                    </label>
                                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="|" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="tm-sep">
                                        <rect key="frame" x="50" y="0.0" width="6" height="18"/>
                                        <fontDescription key="fontDescription" type="system" pointSize="14"/>
                                        <color key="textColor" white="1" alpha="0.4" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                    </label>
                                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="2024" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="tm-year">
                                        <rect key="frame" x="60" y="0.0" width="30" height="18"/>
                                        <fontDescription key="fontDescription" type="system" pointSize="14"/>
                                        <color key="textColor" white="1" alpha="0.7" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                    </label>
                                </subviews>
                            </stackView>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Action, Drama" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="tm-genres">
                                <rect key="frame" x="134" y="88" width="215" height="16"/>
                                <fontDescription key="fontDescription" type="system" pointSize="13"/>
                                <color key="textColor" white="1" alpha="0.5" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                            </label>
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Overview text..." textAlignment="natural" lineBreakMode="tailTruncation" numberOfLines="3" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="tm-overview">
                                <rect key="frame" x="134" y="110" width="215" height="56"/>
                                <fontDescription key="fontDescription" type="system" pointSize="12"/>
                                <color key="textColor" white="1" alpha="0.6" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                            </label>
                        </subviews>
                        <color key="backgroundColor" red="0.14901960784313725" green="0.16862745098039217" blue="0.2196078431372549" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                        <constraints>
                            <constraint firstItem="tm-poster" firstAttribute="top" secondItem="tm-container" secondAttribute="top" constant="12" id="c-p-t"/>
                            <constraint firstItem="tm-poster" firstAttribute="leading" secondItem="tm-container" secondAttribute="leading" constant="12" id="c-p-l"/>
                            <constraint firstItem="tm-container" firstAttribute="bottom" secondItem="tm-poster" secondAttribute="bottom" constant="12" id="c-p-b"/>
                            <constraint firstItem="tm-topLabel" firstAttribute="top" secondItem="tm-container" secondAttribute="top" constant="12" id="c-tl-t"/>
                            <constraint firstItem="tm-topLabel" firstAttribute="leading" secondItem="tm-poster" secondAttribute="trailing" constant="12" id="c-tl-l"/>
                            <constraint firstItem="tm-container" firstAttribute="trailing" secondItem="tm-topLabel" secondAttribute="trailing" constant="12" id="c-tl-r"/>
                            <constraint firstItem="tm-title" firstAttribute="top" secondItem="tm-topLabel" secondAttribute="bottom" constant="4" id="c-ti-t"/>
                            <constraint firstItem="tm-title" firstAttribute="leading" secondItem="tm-poster" secondAttribute="trailing" constant="12" id="c-ti-l"/>
                            <constraint firstItem="tm-container" firstAttribute="trailing" secondItem="tm-title" secondAttribute="trailing" constant="12" id="c-ti-r"/>
                            <constraint firstItem="tm-ratingStack" firstAttribute="top" secondItem="tm-title" secondAttribute="bottom" constant="6" id="c-rs-t"/>
                            <constraint firstItem="tm-ratingStack" firstAttribute="leading" secondItem="tm-poster" secondAttribute="trailing" constant="12" id="c-rs-l"/>
                            <constraint firstItem="tm-genres" firstAttribute="top" secondItem="tm-ratingStack" secondAttribute="bottom" constant="8" id="c-g-t"/>
                            <constraint firstItem="tm-genres" firstAttribute="leading" secondItem="tm-poster" secondAttribute="trailing" constant="12" id="c-g-l"/>
                            <constraint firstItem="tm-container" firstAttribute="trailing" secondItem="tm-genres" secondAttribute="trailing" constant="12" id="c-g-r"/>
                            <constraint firstItem="tm-overview" firstAttribute="top" secondItem="tm-genres" secondAttribute="bottom" constant="6" id="c-o-t"/>
                            <constraint firstItem="tm-overview" firstAttribute="leading" secondItem="tm-poster" secondAttribute="trailing" constant="12" id="c-o-l"/>
                            <constraint firstItem="tm-container" firstAttribute="trailing" secondItem="tm-overview" secondAttribute="trailing" constant="12" id="c-o-r"/>
                        </constraints>
                    </view>
                </subviews>
                <constraints>
                    <constraint firstItem="tm-container" firstAttribute="top" secondItem="cv" secondAttribute="top" id="c-ct-t"/>
                    <constraint firstItem="tm-container" firstAttribute="leading" secondItem="cv" secondAttribute="leading" id="c-ct-l"/>
                    <constraint firstItem="cv" firstAttribute="trailing" secondItem="tm-container" secondAttribute="trailing" id="c-ct-r"/>
                    <constraint firstItem="cv" firstAttribute="bottom" secondItem="tm-container" secondAttribute="bottom" id="c-ct-b"/>
                </constraints>
            </collectionViewCellContentView>
            <connections>
                <outlet property="posterImageView" destination="tm-poster" id="out-poster"/>
                <outlet property="topMatchLabel" destination="tm-topLabel" id="out-topLabel"/>
                <outlet property="titleLabel" destination="tm-title" id="out-title"/>
                <outlet property="ratingLabel" destination="tm-rating" id="out-rating"/>
                <outlet property="starImageView" destination="tm-star" id="out-star"/>
                <outlet property="yearLabel" destination="tm-year" id="out-year"/>
                <outlet property="genresLabel" destination="tm-genres" id="out-genres"/>
                <outlet property="overviewLabel" destination="tm-overview" id="out-overview"/>
                <outlet property="containerView" destination="tm-container" id="out-container"/>
            </connections>
        </collectionViewCell>
    </objects>
</document>
